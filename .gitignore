# Training data — gitignore all, selectively un-ignore small data
data/
!data/.gitkeep
!data/lite/pretrain/
!data/nano/pretrain/
!data/pro/pretrain/
!data/lite/sft/
!data/lite/dpo/
!data/nano/sft/
!data/nano/dpo/
!data/pro/sft/
!data/pro/dpo/
!data/benchmarks/
!data/raw/.gitkeep

# Tokenizer checkpoints (keep 12K, ignore test)

# Build artifacts
build/
dist/
gleamlm.egg-info/

# Documentation
docs/

# TensorBoard logs
**/runs/

# Images (training curves)
images/

# IDE
.vscode/
.idea/
.DS_Store

# IDE config
opencode.json
.claude/
AGENTS.md

# Local issue tracker (internal planning)
.scratch/

# Lint & type-check caches
.ruff_cache/
.mypy_cache/

# Pytest cache
.pytest_cache/

# Temporary files
*.log
temp_*
infer_result.txt

# Stale test data patterns
data/test_splits/
data/splits/*.npy
*.backup