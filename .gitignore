# Python
__pycache__/
*.pyc
*.pyo

# Model checkpoints (root level only, keep directory structure)
/checkpoints/*
!/checkpoints/.gitkeep
!/checkpoints/runs/
/checkpoints/runs/*
!/checkpoints/runs/.gitkeep

# Training data (keep directory structure)
data/*
!data/.gitkeep
!data/raw/
data/raw/*
!data/raw/.gitkeep
!data/splits/
data/splits/*
!data/splits/.gitkeep

# Images (training curves, etc.)
images/

# Documentation (internal, not for public repo)
docs/

# Temporary files
temp_*
infer_result.txt

# Test tokenizer (only the test files, keep production bpe_32k)
tokenizer/checkpoints/test_bpe.model
tokenizer/checkpoints/test_bpe.vocab

# Internal debug tools
tools/_read_tb.py
tools/check_ckpt.py
tools/make_small_data.py
tools/quick_run.py
